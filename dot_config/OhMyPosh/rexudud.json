{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": "<#45F1C2><b>⚡</b></><b>{{ .UserName }}</b> <#26C6DA>❯</><#45F1C2>❯</> ",
    "foreground": "#CD4277",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "{{ .Icon }} {{ .HostName }} ",
          "foreground": "#00c983",
          "background": "#003543",
          "type": "os",
          "style": "diamond"
        },
        {
          "options": {
            "folder_icon": "\uf115",
            "folder_separator_icon": "/",
            "home_icon": "\ueb06 \u21aa",
            "style": "full"
          },
          "template": " {{ .Path }} ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#6BAAB8",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "branch_icon": " <black>\ue0a0 </>",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf0c7 {{ .StashCount }}{{ end }} ",
          "foreground": "black",
          "powerline_symbol": "\ue0b0",
          "background": "#FCA17D",
          "type": "git",
          "style": "powerline",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FFEB3B{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#FFCC80{{ end }}",
            "{{ if gt .Ahead 0 }}#B388FF{{ end }}",
            "{{ if gt .Behind 0 }}#B388FB{{ end }}"
          ]
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "fetch_package_manager": true
          },
          "template": "{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }}{{ end }}",
          "foreground": "#ffffff",
          "background": "transparent",
          "type": "node",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "options": {
            "extensions": [
              "bun.lock",
              "bun.lockb"
            ]
          },
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#cc7eda> |</>",
          "foreground": "#ffffff",
          "background": "transparent",
          "type": "bun",
          "style": "plain"
        },
        {
          "options": {
            "extensions": [
              "package-lock.json"
            ]
          },
          "template": " \ue718 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}{{.Full}}<#cc7eda> |</>",
          "foreground": "#ffffff",
          "background": "transparent",
          "type": "npm",
          "style": "plain"
        },
        {
          "options": {
            "always_enabled": true,
            "style": "round"
          },
          "template": " \ueba2 {{ .FormattedMs }}",
          "foreground": "#ADD8E6",
          "powerline_symbol": "\ue0b2",
          "background": "transparent",
          "type": "executiontime",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "options": {
            "time_format": "15:04"
          },
          "template": " <#cc7eda>| </>\uf017 {{ .CurrentDate | date .Format }}",
          "foreground": "blue",
          "powerline_symbol": "\ue0b2",
          "background": "transparent",
          "type": "time",
          "style": "plain",
          "invert_powerline": true
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\ue3bf ",
          "foreground": "#cd5e42",
          "type": "root",
          "style": "plain"
        },
        {
          "template": "<#45F1C2><b>⚡</b></><b>{{ .UserName }}</b> <#26C6DA>❯</><#45F1C2>❯</>",
          "foreground": "#CD4277",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 4,
  "final_space": true
}
